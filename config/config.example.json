{
  "_comment": "Radio Kiosk configuration. Host this file at a public URL and pass --config-url to install.sh.",

  "station": {
    "name": "WLCB 101.5 FM",
    "tagline": "Community Radio for the Lakes",
    "logo_url": "https://yourstation.com/logo.png",
    "website_url": "https://yourstation.com",
    "qr_target": "https://yourstation.com",
    "accent_color": "#3b82f6"
  },

  "nowplaying": {
    "enabled": true,
    "url": "https://yourstation.com/nowplaying.json",
    "format": "json",
    "poll_interval_seconds": 10,
    "request_headers": {},
    "field_artist": "artist",
    "field_title": "title"
  },

  "slides": [
    {
      "artist": "BREAK",
      "url": "https://yourstation.com/slides/sponsor.jpg"
    },
    {
      "artist": "BREAK",
      "title": "Underwriting",
      "url": "https://yourstation.com/slides/underwriting.html"
    },
    {
      "artist_regex": "^(PROMO|PSA|SPOT)",
      "url": "https://yourstation.com/slides/promo.jpg"
    }
  ],

  "display": {
    "rotation": 0,
    "theme": "dark",
    "show_clock": true,
    "show_qr_code": true,
    "ui_poll_interval_seconds": 5
  },

  "cloudflare": {
    "enabled": false,
    "tunnel_token": "",
    "vnc_enabled": true,
    "vnc_password": "kiosk1234"
  },

  "update": {
    "auto_update_enabled": true,
    "update_interval_hours": 6,
    "git_branch": "main"
  }
}
